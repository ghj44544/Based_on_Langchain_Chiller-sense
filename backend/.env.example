APP_NAME=Chiller Fault Diagnosis LangChain System
APP_ENV=dev
DATABASE_URL=sqlite:///./chiller_fault.db

UPLOAD_DIR=uploads
REPORT_DIR=reports

MODEL_PATH=M1DCNN-集成/saved_models_ultra/largeDataset_enhanced_model.mat
SCALER_PATH=saved_models/scaler.pkl
FEATURE_COLUMNS_PATH=saved_models/feature_columns.json
MODEL_FEATURE_COLUMNS_PATH=
LABEL_MAP_PATH=saved_models/label_map.json
MATLAB_PROJECT_DIR=M1DCNN-集成
MATLAB_PREDICT_FUNCTION_DIR=app/matlab
MATLAB_ENGINE_MODE=auto
MATLAB_SHARED_ENGINE_NAME=
MATLAB_START_OPTIONS=-nodesktop -nosplash

LLM_PROVIDER=openai_compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT=60

ENABLE_LLM=false
ENABLE_RAG=false
