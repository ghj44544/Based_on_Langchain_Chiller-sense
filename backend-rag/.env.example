APP_NAME=Chiller Fault Diagnosis LangChain System
APP_ENV=dev
DATABASE_URL=sqlite:///./chiller_fault_rag.db

UPLOAD_DIR=uploads
REPORT_DIR=reports

MODEL_PATH=saved_models/ict_sklearn_baseline.joblib
SCALER_PATH=saved_models/scaler.pkl
FEATURE_COLUMNS_PATH=saved_models/feature_columns.json
MODEL_FEATURE_COLUMNS_PATH=saved_models/model_feature_columns.json
LABEL_MAP_PATH=saved_models/label_map.json
MATLAB_PROJECT_DIR=M1DCNN-集成
MATLAB_PREDICT_FUNCTION_DIR=app/matlab
MATLAB_ENGINE_MODE=auto
MATLAB_SHARED_ENGINE_NAME=
MATLAB_START_OPTIONS=-nodesktop -nosplash

LLM_PROVIDER=openai_compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT=60

ENABLE_LLM=false
ENABLE_RAG=true

KNOWLEDGE_BASE_DIR=knowledge_base
RAG_VECTOR_DIR=chroma_db
RAG_COLLECTION_NAME=chiller_sense_kb
RAG_RETRIEVER=hybrid
RAG_TOP_K=4
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
